{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "DefGuard shared Renovate preset",
  "extends": ["config:recommended"],
  "timezone": "Europe/Warsaw",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchBaseBranches": ["dev"],
      "groupName": "rust dependencies",
      "schedule": ["* * * * 0,6"]
    },
    {
      "matchManagers": ["npm"],
      "matchBaseBranches": ["dev"],
      "groupName": "frontend dependencies",
      "schedule": ["* * * * 0,6"]
    },
    {
      "matchManagers": ["pub"],
      "matchBaseBranches": ["dev"],
      "groupName": "dart/flutter dependencies",
      "schedule": ["* * * * 0,6"]
    },
    {
      "matchDatasources": ["docker"],
      "matchBaseBranches": ["dev"],
      "groupName": "docker base images",
      "schedule": ["* * * * 0,6"]
    },
    {
      "matchManagers": ["github-actions"],
      "matchBaseBranches": ["dev"],
      "groupName": "github actions",
      "schedule": ["* * * * 0,6"]
    },
    {
      "description": "Disable routine updates on stable, release, and main branches",
      "matchBaseBranches": ["/^stable/", "/^release/", "main"],
      "enabled": false
    },
    {
      "description": "Re-enable for vulnerability alerts on all branches",
      "isVulnerabilityAlert": true,
      "enabled": true
    }
  ]
}
