{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "DefGuard shared Renovate preset",
  "extends": ["config:best-practices"],
  "timezone": "Europe/Warsaw",
  "baseBranchPatterns": ["dev", "main", "/^stable\\//", "/^release\\//"],
  "labels": ["dependencies", "renovate"],
  "dependencyDashboard": true,
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "recreateClosed": true,
    "addLabels": ["security"],
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Only security updates on stable, release, and main branches",
      "matchBaseBranches": ["/^stable/.*/", "/^release/.*/", "main"],
      "enabled": false,
      "matchPackageNames": ["*"]
    },
    {
      "matchManagers": ["cargo"],
      "matchBaseBranches": ["dev"],
      "groupName": "rust dependencies",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["npm"],
      "matchBaseBranches": ["dev"],
      "groupName": "frontend dependencies",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["pub"],
      "matchBaseBranches": ["dev"],
      "groupName": "dart/flutter dependencies",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchBaseBranches": ["dev"],
      "groupName": "docker base images",
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["github-actions"],
      "matchBaseBranches": ["dev"],
      "groupName": "github actions",
      "minimumReleaseAge": "7 days"
    }
  ]
}
