{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "DefGuard shared Renovate preset",
  "extends": ["config:recommended"],
  "timezone": "Europe/Warsaw",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "dependencyDashboard": true,
  "packageRules": [
    {
      "description": "Disable all routine updates by default",
      "enabled": false
    },
    {
      "matchManagers": ["cargo"],
      "matchBaseBranches": ["dev"],
      "enabled": true,
      "groupName": "rust dependencies",
      "schedule": ["* * * * 0,6"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["npm"],
      "matchBaseBranches": ["dev"],
      "enabled": true,
      "groupName": "frontend dependencies",
      "schedule": ["* * * * 0,6"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["pub"],
      "matchBaseBranches": ["dev"],
      "enabled": true,
      "groupName": "dart/flutter dependencies",
      "schedule": ["* * * * 0,6"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchDatasources": ["docker"],
      "matchBaseBranches": ["dev"],
      "enabled": true,
      "groupName": "docker base images",
      "schedule": ["* * * * 0,6"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["github-actions"],
      "matchBaseBranches": ["dev"],
      "enabled": true,
      "groupName": "github actions",
      "schedule": ["* * * * 0,6"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Re-enable for vulnerability alerts on all branches",
      "isVulnerabilityAlert": true,
      "enabled": true,
      "groupName": "security updates",
      "minimumReleaseAge": "0 days",
      "additionalLabels": ["security"]
    },
    {
      "isVulnerabilityAlert": true,
      "matchManagers": ["cargo"],
      "groupName": "rust security updates"
    },
    {
      "isVulnerabilityAlert": true,
      "matchManagers": ["npm"],
      "groupName": "frontend security updates"
    },
    {
      "isVulnerabilityAlert": true,
      "matchManagers": ["pub"],
      "groupName": "dart/flutter security updates"
    },
    {
      "isVulnerabilityAlert": true,
      "matchDatasources": ["docker"],
      "groupName": "docker security updates"
    },
    {
      "isVulnerabilityAlert": true,
      "matchManagers": ["github-actions"],
      "groupName": "github actions security updates"
    }
  ]
}
